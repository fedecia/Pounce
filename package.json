{
  "name": "monopolystreet-vite",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check && tsc && vite build",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test tests/static.spec.ts --reporter=line",
    "test:smoke": "node check-render.js",
    "verify": "npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tailwindcss/typography": "^0.5.10",
    "@types/jest": "^30.0.0",
    "autoprefixer": "^10.4.16",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "postcss": "^8.4.32",
    "svelte": "^4.2.8",
    "svelte-check": "^3.6.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.6",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "svelte-preprocess": "^6.0.3"
  }
}
